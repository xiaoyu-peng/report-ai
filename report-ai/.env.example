# ReportAI 环境变量模板 — 复制为 .env 后按需修改
# ===========================================================
# 使用：
#   cp .env.example .env
#   # 填入真实的 API key
#   ./start.sh       # 全栈 docker 一键起（含前后端）
#   ./start.sh --dev # 仅起 mysql+redis，前后端请在 IDE/npm 里自己跑
# ===========================================================

# -------- 1. LLM 提供方（二选一，默认豆包） --------
LLM_PROVIDER=doubao

# 豆包 / 火山方舟（报告生成默认走这里）
DOUBAO_API_KEY=
DOUBAO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
DOUBAO_ENDPOINT=
DOUBAO_MODEL=doubao-seed-2-0-lite-260215

# Claude（可选：LLM_PROVIDER=anthropic 时使用）
ANTHROPIC_API_KEY=

# -------- 2. 自研 MCP：晴天信息检索 / 分析组件 --------
# 见 docs/晴天自研的MCP.txt；appkey 已在 CLAUDE.md 中提及
QINGTIAN_MCP_APPKEY=OOn05z7m

# -------- 3. 联网检索（可选，未配也能跑） --------
TAVILY_API_KEY=

# -------- 4. 其它可覆盖项（一般别改） --------
# JWT 过期（毫秒）
JWT_EXPIRATION=86400000
# JWT 签名密钥：生产务必换成 >= 32 字节随机串
JWT_SECRET=report-ai-jwt-secret-key-2026-must-be-long-enough-for-hs256
